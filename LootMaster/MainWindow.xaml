<Window x:Class="LootMaster.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LootMaster.ViewModels"
        xmlns:cv="clr-namespace:LootMaster.Converters"
        Title="LootMaster 2.0 — Loot Group Editor"
        Icon="GameIcon.ico"
        Height="960" Width="1900"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <cv:NullableToStringConverter x:Key="NullToStr"/>
        <cv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveProgressCommand}"/>
    </Window.InputBindings>

    <DockPanel>

        <!-- ═══════════════════════════════════════════════════════════════════
             TOOLBAR
        ════════════════════════════════════════════════════════════════════ -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Content="{Binding UI.OpenDb}"     Command="{Binding OpenDbCommand}"     Style="{StaticResource ToolbarButton}"
                        ToolTip="{Binding UI.OpenDbTip}"/>
                <Button Content="{Binding UI.OpenLootDb}" Command="{Binding OpenLootDbCommand}" Style="{StaticResource ToolbarButton}"
                        ToolTip="{Binding UI.OpenLootDbTip}"/>
                <Separator/>
                <Button Content="{Binding UI.OpenJson}"   Command="{Binding OpenJsonCommand}"   Style="{StaticResource ToolbarButton}"
                        ToolTip="{Binding UI.OpenJsonTip}"/>
                <Separator/>
                <Button Content="{Binding UI.SaveProgress}" Command="{Binding SaveProgressCommand}" Style="{StaticResource ToolbarButton}"
                        ToolTip="{Binding UI.SaveProgressTip}"/>
                <Button Content="{Binding UI.Export}"       Command="{Binding ExportCommand}"       Style="{StaticResource ToolbarButton}"
                        ToolTip="{Binding UI.ExportTip}"/>
                <Separator/>
                <Button Content="{Binding UI.WriteToDb}"  Command="{Binding SyncDbCommand}"    Style="{StaticResource ToolbarButton}"
                        ToolTip="{Binding UI.WriteTip}"/>
                <Separator/>
                <Button Content="{Binding UI.ImportSql}"  Command="{Binding ImportSqlCommand}" Style="{StaticResource ToolbarButton}"
                        ToolTip="{Binding UI.ImportSqlTip}"/>
                <Separator/>
                <TextBlock Text="{Binding UI.Search}" VerticalAlignment="Center" Margin="4,0"/>
                <TextBox   Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                           Width="200" VerticalAlignment="Center" Margin="2,0"/>
                <Separator/>
                <CheckBox  Content="{Binding UI.OnlyUnproc}"
                           IsChecked="{Binding OnlyUnprocessed}"
                           ToolTip="{Binding UI.OnlyUnprocTip}"
                           VerticalAlignment="Center" Margin="4,0"/>
                <CheckBox  Content="{Binding UI.HlCategories}"
                           IsChecked="{Binding HighlightCategoryGroup}"
                           ToolTip="{Binding UI.HlCatTip}"
                           VerticalAlignment="Center" Margin="4,0"/>
                <Separator/>
                <CheckBox  Content="{Binding UI.ShowNpcId}"
                           IsChecked="{Binding ShowNpcIdColumn}"
                           ToolTip="{Binding UI.ShowNpcIdTip}"
                           VerticalAlignment="Center" Margin="4,0"/>
                <CheckBox  Content="{Binding UI.ShowNpcNames}"
                           IsChecked="{Binding ShowNpcNameColumn}"
                           ToolTip="{Binding UI.ShowNpcNamesTip}"
                           VerticalAlignment="Center" Margin="4,0"/>
                <Separator/>
                <Button Content="{Binding LanguageLabel}"
                        Command="{Binding ToggleLanguageCommand}"
                        Style="{StaticResource ToolbarButton}"
                        ToolTip="{Binding UI.LangTip}"
                        FontWeight="Bold" MinWidth="36"/>
            </ToolBar>
        </ToolBarTray>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <ProgressBar Width="120" Height="14" IsIndeterminate="{Binding IsLoading}"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Loaded JSON files strip -->
        <ItemsControl DockPanel.Dock="Top"
                      ItemsSource="{Binding LoadedJsonFiles}"
                      Visibility="{Binding LoadedJsonFiles.Count, Converter={StaticResource BoolToVis}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="#EEF" BorderBrush="#99B" BorderThickness="1"
                            CornerRadius="3" Margin="4,2" Padding="6,2">
                        <TextBlock Text="{Binding}" FontSize="11"/>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- ═══════════════════════════════════════════════════════════════════
             MAIN SPLIT: left=DataGrid  right=Editor
        ════════════════════════════════════════════════════════════════════ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="MainGridLeft" Width="5*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="2.5*" MinWidth="320"/>
            </Grid.ColumnDefinitions>

            <!-- ─── LEFT: item DataGrid ──────────────────────────────────── -->
            <DataGrid x:Name="ItemsGrid" Grid.Column="0"
                      ItemsSource="{Binding ItemsView}"
                      SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                      RowStyle="{StaticResource ItemRowStyle}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      CanUserReorderColumns="True"
                      SelectionUnit="FullRow"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      GridLinesVisibility="Horizontal"
                      AlternatingRowBackground="#F8F8F8"
                      FontSize="12">
                <DataGrid.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"     Color="#3399FF"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White"/>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <!-- Headers updated in code-behind when language changes -->
                    <DataGridTextColumn Header="Item ID"         Binding="{Binding ItemId}"       Width="80"  CanUserSort="True"/>
                    <DataGridTextColumn Header="Предмет"         Binding="{Binding ItemName}"     Width="200" CanUserSort="True"/>
                    <DataGridTextColumn Header="Cat ID"          Binding="{Binding CategoryId}"   Width="70"  CanUserSort="True"/>
                    <DataGridTextColumn Header="Категория"       Binding="{Binding CategoryName}" Width="180" CanUserSort="True"/>

                    <DataGridTextColumn Header="NPC ID"
                                        Binding="{Binding NpcIdsText}"
                                        Width="120"
                                        Visibility="{Binding DataContext.ShowNpcIdColumn,
                                            RelativeSource={RelativeSource AncestorType=Window},
                                            Converter={StaticResource BoolToVis}}"/>

                    <DataGridTextColumn Header="NPC"
                                        Binding="{Binding NpcNamesText}"
                                        Width="220"
                                        Visibility="{Binding DataContext.ShowNpcNameColumn,
                                            RelativeSource={RelativeSource AncestorType=Window},
                                            Converter={StaticResource BoolToVis}}"/>

                    <DataGridTextColumn Header="Группа (предмет)"   Binding="{Binding ItemGroup,     Converter={StaticResource NullToStr}}" Width="110" CanUserSort="True"/>
                    <DataGridTextColumn Header="Шанс (предмет)"     Binding="{Binding ItemChance,    Converter={StaticResource NullToStr}}" Width="110" CanUserSort="True"/>
                    <DataGridTextColumn Header="Группа (категория)" Binding="{Binding CategoryGroup, Converter={StaticResource NullToStr}}" Width="120" CanUserSort="True"/>
                    <DataGridTextColumn Header="Шанс (категория)"   Binding="{Binding CategoryChance,Converter={StaticResource NullToStr}}" Width="120" CanUserSort="True"/>
                    <DataGridTextColumn Header="Итог. группа"       Binding="{Binding EffectiveGroup, Converter={StaticResource NullToStr}}" Width="100" CanUserSort="True"/>
                    <DataGridTextColumn Header="Итог. шанс"         Binding="{Binding EffectiveChance,Converter={StaticResource NullToStr}}" Width="100" CanUserSort="True"/>
                    <DataGridTextColumn Header="Loot Pack ID"        Binding="{Binding LootPackIdsText}"                                   Width="120" CanUserSort="True"/>
                    <DataGridTextColumn Header="Группа (БД)"        Binding="{Binding DbGroup,        Converter={StaticResource NullToStr}}" Width="100" CanUserSort="True"/>
                    <DataGridTextColumn Header="Шанс (БД)"          Binding="{Binding DbChance,       Converter={StaticResource NullToStr}}" Width="100" CanUserSort="True"/>
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#DDD"/>

            <!-- ─── RIGHT: Editor panel ──────────────────────────────────── -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="6">

                    <!-- Info box -->
                    <GroupBox Header="{Binding UI.GbSelectedItem}" Style="{StaticResource SectionFrame}" Height="160">
                        <StackPanel>
                            <TextBlock FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"
                                       Text="{Binding SelectedItemInfoText}"/>
                            <TextBlock FontFamily="Consolas" FontSize="11" Text="{Binding UI.NpcLabel}" Margin="0,4,0,2"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"
                                           Text="{Binding SelectedItem.NpcNamesText, FallbackValue='—'}"/>
                            </ScrollViewer>
                        </StackPanel>
                    </GroupBox>

                    <!-- Item settings -->
                    <GroupBox Style="{StaticResource SectionFrame}">
                        <GroupBox.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding UI.GbItemSettings}" VerticalAlignment="Center"/>
                                <Button Content="?" Command="{Binding ShowGroupHelpCommand}"
                                        Width="18" Height="18" Margin="6,0,0,0" Padding="0"
                                        FontSize="11" FontWeight="Bold"
                                        ToolTip="{Binding UI.GroupHelpTip}"/></StackPanel>
                        </GroupBox.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding UI.ItemGroupLabel}" VerticalAlignment="Center" Margin="0,4"/>
                            <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding ItemGroupText, UpdateSourceTrigger=PropertyChanged}"
                                       Margin="4,4" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding UI.ItemChanceLabel}" VerticalAlignment="Center" Margin="0,4"/>
                            <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding ItemChanceText, UpdateSourceTrigger=PropertyChanged}"
                                       Margin="4,4" VerticalAlignment="Center"/>

                            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                        Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="{Binding UI.BtnApply}" Command="{Binding ApplyItemCommand}"
                                        Style="{StaticResource ToolbarButton}"
                                        ToolTip="{Binding UI.BtnApplyTip}"/>
                                <Button Content="{Binding UI.BtnReset}" Command="{Binding ClearItemCommand}"
                                        Style="{StaticResource ToolbarButton}"
                                        ToolTip="{Binding UI.BtnResetItemTip}"/>
                                <Button Content="{Binding UI.BtnApplyAllFromDb}"
                                        Command="{Binding ApplyAllFromDbCommand}"
                                        Padding="10,4" Margin="3,0"
                                        ToolTip="{Binding UI.BtnApplyAllTip}"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <!-- Category settings -->
                    <GroupBox Header="{Binding UI.GbCatSettings}" Style="{StaticResource SectionFrame}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding UI.CatGroupLabel}" VerticalAlignment="Center" Margin="0,4"/>
                            <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding CategoryGroupText, UpdateSourceTrigger=PropertyChanged}"
                                       Margin="4,4" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding UI.CatChanceLabel}" VerticalAlignment="Center" Margin="0,4"/>
                            <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding CategoryChanceText, UpdateSourceTrigger=PropertyChanged}"
                                       Margin="4,4" VerticalAlignment="Center"/>

                            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                        Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="{Binding UI.BtnApplyCat}" Command="{Binding ApplyCategoryCommand}"
                                        Padding="10,4" Margin="3,0"
                                        ToolTip="{Binding UI.BtnApplyCatTip}"/>
                                <Button Content="{Binding UI.BtnReset}" Command="{Binding ClearCategoryCommand}"
                                        Style="{StaticResource ToolbarButton}"
                                        ToolTip="{Binding UI.BtnResetCatTip}"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <!-- Navigation -->
                    <GroupBox Header="{Binding UI.GbNavigation}" Style="{StaticResource SectionFrame}">
                        <WrapPanel>
                            <Button Content="{Binding UI.BtnPrev}"       Command="{Binding PrevCommand}"            Style="{StaticResource ToolbarButton}"
                                    ToolTip="{Binding UI.BtnPrevTip}"/>
                            <Button Content="{Binding UI.BtnNext}"       Command="{Binding NextCommand}"            Style="{StaticResource ToolbarButton}"
                                    ToolTip="{Binding UI.BtnNextTip}"/>
                            <Button Content="{Binding UI.BtnNextUnproc}" Command="{Binding NextUnprocessedCommand}" Style="{StaticResource ToolbarButton}"
                                    ToolTip="{Binding UI.BtnNextUnprocTip}"/>
                        </WrapPanel>
                    </GroupBox>

                    <!-- NPC browser -->
                    <GroupBox Header="{Binding UI.GbNpcBrowser}" Style="{StaticResource SectionFrame}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="70"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="110"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="{Binding NpcListLabelText}" Margin="0,0,0,4"/>
                            <ListBox   x:Name="NpcListBox" Grid.Row="1"
                                       ItemsSource="{Binding NpcListItems}"
                                       SelectedItem="{Binding SelectedNpcText, Mode=TwoWay}"
                                       ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                            <TextBlock Grid.Row="3" Text="{Binding NpcDetailLabelText}" Margin="0,4,0,4"/>
                            <DataGrid  x:Name="NpcDetailGrid" Grid.Row="4"
                                       ItemsSource="{Binding NpcDetailItems}"
                                       SelectedItem="{Binding SelectedNpcDetailItem, Mode=TwoWay}"
                                       AutoGenerateColumns="False"
                                       IsReadOnly="True"
                                       SelectionMode="Single"
                                       GridLinesVisibility="Horizontal"
                                       FontSize="11">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HighlightState}" Value="Done">
                                                <Setter Property="Background" Value="#E6FFE6"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding HighlightState}" Value="Category">
                                                <Setter Property="Background" Value="#FFF7CC"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <!-- Headers updated in code-behind when language changes -->
                                    <DataGridTextColumn Header="Item ID"  Binding="{Binding ItemId}"                                             Width="75"/>
                                    <DataGridTextColumn Header="Предмет"  Binding="{Binding ItemName}"                                           Width="*"/>
                                    <DataGridTextColumn Header="Pack ID"  Binding="{Binding LootPackId, Converter={StaticResource NullToStr}}"   Width="65"/>
                                    <DataGridTextColumn Header="Группа"   Binding="{Binding EffectiveGroup,  Converter={StaticResource NullToStr}}" Width="65"/>
                                    <DataGridTextColumn Header="Шанс"     Binding="{Binding EffectiveChance, Converter={StaticResource NullToStr}}" Width="65"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </GroupBox>

                    <!-- Summary -->
                    <GroupBox Header="{Binding UI.GbSummary}" Style="{StaticResource SectionFrame}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding SummaryLeft}"  FontFamily="Consolas" FontSize="11"/>
                            <TextBlock Grid.Column="2" Text="{Binding SummaryRight}" FontFamily="Consolas" FontSize="11"/>
                        </Grid>
                    </GroupBox>

                </StackPanel>
            </ScrollViewer>

        </Grid>
    </DockPanel>
</Window>
